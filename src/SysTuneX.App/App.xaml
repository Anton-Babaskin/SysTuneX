<Application x:Class="SysTuneX.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:SysTuneX.App.Helpers"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Styles -->
            <Style x:Key="RiskBadgeSafe" TargetType="Border">
                <Setter Property="Background" Value="#2220C020" />
                <Setter Property="BorderBrush" Value="#4420C020" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="6,2" />
            </Style>
            <Style x:Key="RiskBadgeModerate" TargetType="Border">
                <Setter Property="Background" Value="#22FFA500" />
                <Setter Property="BorderBrush" Value="#44FFA500" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="6,2" />
            </Style>
            <Style x:Key="RiskBadgeAdvanced" TargetType="Border">
                <Setter Property="Background" Value="#22FF4444" />
                <Setter Property="BorderBrush" Value="#44FF4444" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="6,2" />
            </Style>

            <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
            <SolidColorBrush x:Key="AccentBrushLight" Color="#A78BFA" />
            <SolidColorBrush x:Key="CardBackground" Color="#1E1E2E" />
            <SolidColorBrush x:Key="SurfaceBackground" Color="#11111B" />

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <helpers:ZeroToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <helpers:NonEmptyStringToBoolConverter x:Key="IntToBoolConverter" />
            <helpers:RiskToBrushConverter x:Key="RiskToBrushConverter" />
            <helpers:StatusToBrushConverter x:Key="StatusToBrushConverter" />
            <helpers:BoolToRunningTextConverter x:Key="BoolToRunningTextConverter" />
            <helpers:RiskToBackgroundConverter x:Key="RiskToBackground" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
