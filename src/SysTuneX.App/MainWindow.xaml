<ui:FluentWindow x:Class="SysTuneX.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="SysTuneX"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>

        <ui:NavigationView x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="220">

            <ui:NavigationView.Header>
                <Grid Margin="12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="28" Height="28">
                            <Canvas Width="24" Height="24">
                                <!-- Lightning bolt icon -->
                                <Path Fill="{StaticResource AccentBrush}"
                                      Data="M13 2L4.5 13.5H11L10 22L19.5 10.5H13L13 2Z" />
                            </Canvas>
                        </Viewbox>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="SysTuneX" FontSize="18" FontWeight="Bold" LineHeight="20" />
                            <TextBlock Text="Game Optimizer" FontSize="10" Opacity="0.5" LineHeight="12" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Theme toggle -->
                    <ui:Button x:Name="ThemeToggleButton" Grid.Column="1"
                               VerticalAlignment="Center"
                               Appearance="Transparent"
                               Click="ThemeToggle_Click"
                               ToolTip="Toggle dark/light theme">
                        <ui:SymbolIcon x:Name="ThemeIcon" Symbol="WeatherMoon24" FontSize="18" />
                    </ui:Button>
                </Grid>
            </ui:NavigationView.Header>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" Icon="{ui:SymbolIcon Home24}"
                                       TargetPageType="{x:Type local:DashboardPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItem Content="Game Profiles" Icon="{ui:SymbolIcon XboxController24}"
                                       TargetPageType="{x:Type local:ProfilesPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItem Content="Startup" Icon="{ui:SymbolIcon Rocket24}"
                                       TargetPageType="{x:Type local:StartupPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItemSeparator />
                <ui:NavigationViewItem Content="Gaming" Icon="{ui:SymbolIcon Games24}"
                                       TargetPageType="{x:Type local:GamingPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItem Content="Services" Icon="{ui:SymbolIcon AppsList24}"
                                       TargetPageType="{x:Type local:ServicesPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItem Content="Privacy" Icon="{ui:SymbolIcon Shield24}"
                                       TargetPageType="{x:Type local:PrivacyPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItem Content="Network" Icon="{ui:SymbolIcon Wifi124}"
                                       TargetPageType="{x:Type local:NetworkPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItem Content="Cleanup" Icon="{ui:SymbolIcon Delete24}"
                                       TargetPageType="{x:Type local:CleanupPage}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
                <ui:NavigationViewItemSeparator />
                <ui:NavigationViewItem Content="Win 11 Tweaks" Icon="{ui:SymbolIcon Desktop24}"
                                       TargetPageType="{x:Type local:Windows11Page}"
                                       xmlns:local="clr-namespace:SysTuneX.App.Views" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.ContentOverlay>
                <Grid>
                    <ui:TitleBar Title="SysTuneX" ShowMaximize="True" ShowMinimize="True" />
                </Grid>
            </ui:NavigationView.ContentOverlay>

        </ui:NavigationView>

    </Grid>
</ui:FluentWindow>
