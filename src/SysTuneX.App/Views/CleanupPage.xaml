<Page x:Class="SysTuneX.App.Views.CleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Cleanup">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="24,16,24,0">
            <StackPanel>
                <TextBlock Text="System Cleanup" FontSize="28" FontWeight="Bold" />
                <TextBlock Text="Clean temp files and remove bloatware" Opacity="0.6" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12">
            <StackPanel>

                <!-- Temp Files Card -->
                <ui:Card Margin="0,0,0,16" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Temporary Files" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Opacity="0.6" Margin="0,4,0,0">
                                <Run Text="Cleanable size:" />
                                <Run Text="{Binding ViewModel.CleanableSize, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock Text="{Binding ViewModel.LastCleanResult}" Foreground="#20C020"
                                       Margin="0,4,0,0" FontSize="12" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="Clean Now" Icon="{ui:SymbolIcon Delete24}"
                                   Appearance="Primary" VerticalAlignment="Center"
                                   Command="{Binding ViewModel.CleanTempCommand}"
                                   IsEnabled="{Binding ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                    </Grid>
                </ui:Card>

                <!-- Bloatware Section -->
                <TextBlock Text="Removable Apps" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

                <ui:InfoBar Title="Scan in progress..." IsOpen="{Binding ViewModel.IsScanning}"
                            Severity="Informational" Margin="0,0,0,8" />

                <ItemsControl ItemsSource="{Binding ViewModel.RemovableApps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="16,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding PackageName}" Opacity="0.4" FontSize="11" />
                                    </StackPanel>

                                    <ui:Button Grid.Column="1" Content="Remove" Appearance="Danger"
                                               VerticalAlignment="Center"
                                               Command="{Binding DataContext.ViewModel.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}"
                                               IsEnabled="{Binding IsRemoving, Converter={StaticResource InverseBooleanConverter}}" />
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="No bloatware found — your system is clean!"
                           Visibility="{Binding ViewModel.RemovableApps.Count, Converter={StaticResource IntToVisibilityConverter}}"
                           Opacity="0.5" HorizontalAlignment="Center" Margin="0,20,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
