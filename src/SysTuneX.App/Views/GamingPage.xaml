<Page x:Class="SysTuneX.App.Views.GamingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Gaming Tweaks">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Gaming Tweaks" FontSize="28" FontWeight="Bold" />
                <TextBlock Opacity="0.6" Margin="0,4,0,0">
                    <Run Text="{Binding ViewModel.AppliedCount, Mode=OneWay}" />
                    <Run Text="of" />
                    <Run Text="{Binding ViewModel.TotalCount, Mode=OneWay}" />
                    <Run Text="tweaks applied" />
                </TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Content="Apply All" Icon="{ui:SymbolIcon CheckmarkCircle24}"
                           Appearance="Primary" Margin="0,0,8,0"
                           Command="{Binding ViewModel.ApplyAllCommand}" />
                <ui:Button Content="Revert All" Icon="{ui:SymbolIcon ArrowReset24}"
                           Command="{Binding ViewModel.RevertAllCommand}" />
            </StackPanel>
        </Grid>

        <!-- Tweaks List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12">
            <ItemsControl ItemsSource="{Binding ViewModel.Tweaks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                        <Border Margin="8,0,0,0" CornerRadius="4" Padding="6,2"
                                                Background="{Binding Risk, Converter={StaticResource RiskToBrushConverter}}"
                                                Opacity="0.3">
                                            <TextBlock Text="{Binding Risk}" FontSize="10"
                                                       Foreground="{Binding Risk, Converter={StaticResource RiskToBrushConverter}}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Opacity="0.5" FontSize="12" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Status Indicator -->
                                <Ellipse Grid.Column="1" Width="8" Height="8" Margin="12,0"
                                         Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                         VerticalAlignment="Center" />

                                <!-- Toggle -->
                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                                 VerticalAlignment="Center"
                                                 Command="{Binding DataContext.ViewModel.ToggleTweakCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                 CommandParameter="{Binding}" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" Background="#88000000"
              Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
                <TextBlock Text="Applying changes..." Margin="0,12,0,0" FontSize="14" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
