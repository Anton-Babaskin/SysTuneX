<Page x:Class="SysTuneX.App.Views.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Network">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="24,16,24,0">
            <StackPanel>
                <TextBlock Text="Network Optimization" FontSize="28" FontWeight="Bold" />
                <TextBlock Opacity="0.6" Margin="0,4,0,0">
                    <Run Text="{Binding ViewModel.AppliedCount, Mode=OneWay}" />
                    <Run Text="network tweaks applied" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12">
            <StackPanel>

                <!-- DNS Card -->
                <ui:Card Margin="0,0,0,16" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Quick DNS Switch" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Current DNS" Opacity="0.6" FontSize="12" />
                                <TextBlock FontSize="14" Margin="0,4,0,8">
                                    <Run Text="{Binding ViewModel.CurrentDnsPrimary}" FontWeight="SemiBold" />
                                    <Run Text=" / " Foreground="#80FFFFFF" />
                                    <Run Text="{Binding ViewModel.CurrentDnsSecondary}" FontWeight="SemiBold" />
                                </TextBlock>
                                <ComboBox ItemsSource="{Binding ViewModel.DnsPresetNames}"
                                          SelectedIndex="{Binding ViewModel.SelectedDnsPreset}"
                                          Width="200" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <ui:Button Content="Apply DNS" Appearance="Primary" Margin="0,0,0,4"
                                           Command="{Binding ViewModel.ApplyDnsCommand}" />
                                <ui:Button Content="Reset to DHCP"
                                           Command="{Binding ViewModel.ResetDnsCommand}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Network Tweaks -->
                <ItemsControl ItemsSource="{Binding ViewModel.Tweaks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                            <Border Margin="8,0,0,0" CornerRadius="4" Padding="6,2"
                                                    Background="{Binding Risk, Converter={StaticResource RiskToBrushConverter}}"
                                                    Opacity="0.3">
                                                <TextBlock Text="{Binding Risk}" FontSize="10"
                                                           Foreground="{Binding Risk, Converter={StaticResource RiskToBrushConverter}}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Opacity="0.5" FontSize="12"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Ellipse Grid.Column="1" Width="8" Height="8" Margin="12,0"
                                             Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                             VerticalAlignment="Center" />

                                    <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                                     VerticalAlignment="Center"
                                                     Command="{Binding DataContext.ViewModel.ToggleTweakCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                     CommandParameter="{Binding}" />
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
