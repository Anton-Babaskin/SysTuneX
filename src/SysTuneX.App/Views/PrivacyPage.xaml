<Page x:Class="SysTuneX.App.Views.PrivacyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SysTuneX.App.Helpers"
      Title="Privacy">

    <Page.Resources>
        <helpers:RiskToBrushConverter x:Key="RiskToBrush" />
        <helpers:StatusToBrushConverter x:Key="StatusToBrush" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Privacy" FontSize="28" FontWeight="Bold" />
                <TextBlock Opacity="0.6" Margin="0,4,0,0">
                    <Run Text="{Binding ViewModel.AppliedCount, Mode=OneWay}" />
                    <Run Text="privacy tweaks applied" />
                </TextBlock>
            </StackPanel>
            <ui:Button Grid.Column="1" Content="Apply All" Icon="{ui:SymbolIcon Shield24}"
                       Appearance="Primary" VerticalAlignment="Center"
                       Command="{Binding ViewModel.ApplyAllCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12">
            <StackPanel>
                <!-- Telemetry Host Blocking Card -->
                <ui:Card Margin="0,0,0,12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Block Telemetry Hosts" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Blocks 14 Microsoft telemetry domains via hosts file"
                                       Opacity="0.5" FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ViewModel.HostsBlocked}"
                                         VerticalAlignment="Center"
                                         Command="{Binding ViewModel.ToggleHostsBlockCommand}" />
                    </Grid>
                </ui:Card>

                <!-- Privacy Tweaks -->
                <ItemsControl ItemsSource="{Binding ViewModel.Tweaks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding Description}" Opacity="0.5" FontSize="12"
                                                   Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Ellipse Grid.Column="1" Width="8" Height="8" Margin="12,0"
                                             Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                             VerticalAlignment="Center" />

                                    <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                                     VerticalAlignment="Center"
                                                     Command="{Binding DataContext.ViewModel.ToggleTweakCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                     CommandParameter="{Binding}" />
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
