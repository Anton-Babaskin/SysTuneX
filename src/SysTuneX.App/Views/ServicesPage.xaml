<Page x:Class="SysTuneX.App.Views.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SysTuneX.App.Helpers"
      Title="Services">

    <Page.Resources>
        <helpers:RiskToBrushConverter x:Key="RiskToBrush" />
        <helpers:BoolToRunningTextConverter x:Key="BoolToRunning" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Windows Services" FontSize="28" FontWeight="Bold" />
                <TextBlock Opacity="0.6" Margin="0,4,0,0">
                    <Run Text="{Binding ViewModel.RunningCount, Mode=OneWay}" />
                    <Run Text="running," />
                    <Run Text="{Binding ViewModel.StoppedCount, Mode=OneWay}" />
                    <Run Text="stopped" />
                </TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Content="Stop All" Icon="{ui:SymbolIcon Stop24}"
                           Appearance="Danger" Margin="0,0,8,0"
                           Command="{Binding ViewModel.StopAllCommand}" />
                <ui:Button Content="Start All" Icon="{ui:SymbolIcon Play24}"
                           Command="{Binding ViewModel.StartAllCommand}" />
            </StackPanel>
        </Grid>

        <!-- Services List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12">
            <ItemsControl ItemsSource="{Binding ViewModel.Services}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                                        <Border Margin="8,0,0,0" CornerRadius="4" Padding="6,2"
                                                Background="{Binding Risk, Converter={StaticResource RiskToBrush}}"
                                                Opacity="0.3">
                                            <TextBlock Text="{Binding Risk}" FontSize="10"
                                                       Foreground="{Binding Risk, Converter={StaticResource RiskToBrush}}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Opacity="0.5" FontSize="12" Margin="0,2,0,0" />
                                </StackPanel>

                                <!-- Service Name -->
                                <TextBlock Grid.Column="1" Text="{Binding ServiceName}"
                                           Opacity="0.4" FontSize="11" Margin="12,0"
                                           VerticalAlignment="Center" />

                                <!-- Status -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="8,3" Margin="4,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2220C020" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#2220C020" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                    <Setter Property="Background" Value="#22888888" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToRunning}}"
                                               FontSize="11" />
                                </Border>

                                <!-- Toggle -->
                                <ui:Button Grid.Column="3" Margin="8,0,0,0" VerticalAlignment="Center"
                                           Command="{Binding DataContext.ViewModel.ToggleServiceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}">
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Content" Value="Stop" />
                                            <Setter Property="Appearance" Value="Danger" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                    <Setter Property="Content" Value="Start" />
                                                    <Setter Property="Appearance" Value="Success" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
