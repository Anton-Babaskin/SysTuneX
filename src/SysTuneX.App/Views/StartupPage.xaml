<Page x:Class="SysTuneX.App.Views.StartupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SysTuneX.App.Helpers"
      Title="Startup Manager">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="24,16,24,0">
            <StackPanel>
                <TextBlock Text="Startup Manager" FontSize="28" FontWeight="Bold" />
                <TextBlock Opacity="0.6" Margin="0,4,0,0">
                    <Run Text="{Binding ViewModel.EnabledCount, Mode=OneWay}" />
                    <Run Text="of" />
                    <Run Text="{Binding ViewModel.TotalCount, Mode=OneWay}" />
                    <Run Text="startup programs enabled" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12"
                      helpers:ScrollViewerHelper.FixMouseWheel="True">
            <ItemsControl ItemsSource="{Binding ViewModel.Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Location Badge -->
                                <Border CornerRadius="4" Padding="6,2" Margin="0,0,12,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33888888" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Location}" Value="HKCU">
                                                    <Setter Property="Background" Value="#331E90FF" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Location}" Value="HKLM">
                                                    <Setter Property="Background" Value="#33FF8C00" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Location}" FontSize="10" FontWeight="SemiBold" />
                                </Border>

                                <!-- Name + Command -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Command}" Opacity="0.45" FontSize="11"
                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- Status dot -->
                                <Ellipse Grid.Column="2" Width="8" Height="8" Margin="12,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#888888" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Fill" Value="#20C020" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <!-- Toggle -->
                                <ui:ToggleSwitch Grid.Column="3" IsChecked="{Binding IsEnabled}"
                                                 VerticalAlignment="Center"
                                                 Command="{Binding DataContext.ViewModel.ToggleItemCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                 CommandParameter="{Binding}" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" Background="#88000000"
              Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" />
                <TextBlock Text="Loading startup items..." Margin="0,12,0,0" FontSize="14" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
